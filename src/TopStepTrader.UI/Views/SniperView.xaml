<UserControl x:Class="TopStepTrader.UI.Views.SniperView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:TopStepTrader.UI.Controls"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- TabControl fills space -->
            <RowDefinition Height="Auto"/> <!-- bottom control bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TabControl: Live Sniper | Sniper Backtest
             ══════════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="0" Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    x:Name="MainTabControl">

            <!-- ══════════════════════════════════════════════════════
                 TAB 1: Live Sniper
                 ══════════════════════════════════════════════════════ -->
            <TabItem Header="🎯  Live Sniper">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20,24,8">

                        <TextBlock Text="🎯  Sniper Trading"
                                   Style="{StaticResource PageTitleStyle}"/>

                        <!-- ── Panel 1: Account / Contract / Parameters ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="20,14" Margin="0,12,0,0">
                            <StackPanel>

                                <!-- Row 1: Account | Contract -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>   <!-- "Account:" -->
                                        <ColumnDefinition Width="180"/>    <!-- Account ComboBox -->
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="220"/>    <!-- ContractSelectorControl -->
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Account:"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Accounts}"
                                              SelectedItem="{Binding SelectedAccount}"
                                              FontSize="26"
                                              Style="{StaticResource UnclippedComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                              IsEnabled="{Binding IsNotRunning}"
                                              ToolTip="Select the account to trade with">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <controls:ContractSelectorControl
                                               Grid.Column="3"
                                               IsEnabled="{Binding IsNotRunning}"
                                               ContractId="{Binding ContractId, Mode=TwoWay,
                                                           UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Border Height="8"/>

                                <!-- Row 2: TP / SL / ScaleIn / Duration -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="TP $ / SL $:"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox Text="{Binding InitialTpAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="44" IsEnabled="{Binding IsNotRunning}"
                                                 ToolTip="Initial take-profit in dollars (e.g. 20)"/>
                                        <TextBlock Text="/" VerticalAlignment="Center" Margin="5,0,5,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBox Text="{Binding InitialSlAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="44" IsEnabled="{Binding IsNotRunning}"
                                                 ToolTip="Initial stop-loss in dollars (e.g. 10)"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="3" Text="Scale factor (k):"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="4"
                                             Text="{Binding ScaleInTriggerTicks, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}"
                                             ToolTip="Scale distance multiplier 'k' (e.g., 0.4 * ATR). Replaces fixed tick distance."/>

                                    <TextBlock Grid.Column="6" Text="Duration (hrs):"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="7"
                                             Text="{Binding DurationHours, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsNotRunning}"
                                             ToolTip="How long to run the sniper session (default 2)"/>

                                    <TextBlock Grid.Column="9" Text="Max Heat (Ticks):"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="10" 
                                             Text="{Binding MaxRiskHeatTicks, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}"
                                             ToolTip="Maximum total tick risk (sum of stop distances). Default 30."/>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 0: Core Parameters -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Size:"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TargetTotalSize, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}" ToolTip="Target maximum contracts (e.g. 10)"/>

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Core %:"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding CoreSizeFraction, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}" ToolTip="Fraction of size allocated to first few adds (e.g. 0.55)"/>

                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Core Adds:"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="7" Text="{Binding CoreAddsCount, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}" ToolTip="Number of entries to split the core size across (e.g. 2)"/>

                                    <!-- Row 1: Tier Sizes -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Mom Add:"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MomentumTierSize, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}" ToolTip="Contracts to add per Momentum tier triggering (e.g. 1)"/>

                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Ext Add:"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding ExtensionTierSize, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}" ToolTip="Contracts to add per Extension tier triggering (if allowed)"/>

                                    <CheckBox Grid.Row="2" Grid.Column="6" Grid.ColumnSpan="2" Content="Allow Ext." IsChecked="{Binding ExtensionAllowed}"
                                              VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                                              IsEnabled="{Binding IsNotRunning}" ToolTip="Allow single-contract adds in extended trend (Tier C)"/>
                                </Grid>

                                <Border Height="8"/>

                                <!-- Structure Fail Exit -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" Content="Struct. Fail Exit"
                                              IsChecked="{Binding EnableStructureFailExit}"
                                              VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                                              IsEnabled="{Binding IsNotRunning}" ToolTip="Enable exit on structure failure (EMA21 break)"/>

                                    <TextBlock Grid.Column="2" Text="EMA21 Break (t):"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="3" Text="{Binding Ema21BreakTicks, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}" ToolTip="Ticks beyond EMA21 to trigger exit"/>

                                    <TextBlock Grid.Column="5" Text="Min Bars:"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="6" Text="{Binding MinBarsBeforeExit, UpdateSourceTrigger=PropertyChanged}"
                                             Width="44" IsEnabled="{Binding IsNotRunning}" ToolTip="Minimum bars in trade before structure check applies"/>
                                </Grid>

                                <Border Height="8"/>

                                <!-- Strategy description -->
                                <TextBlock Text="Strategy: Tiered Pyramid · Core size front-loaded · Momentum adds · Heat cap"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Panel 2: Position Status ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="20,12" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="POSITION"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding PositionDisplay}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4"
                                           Margin="20,0,8,0"
                                           Text="Avg Entry:"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="5"
                                           Text="{Binding AverageEntryDisplay}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="6" 
                                           Margin="20,0,8,0"
                                           Text="Risk Heat:"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="7"
                                           Text="{Binding HeatDisplay}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- ── Panel 3: Signal Log ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="20,14" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="SIGNAL LOG"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           Margin="0,0,0,8"/>
                                <ListBox x:Name="LogList"
                                         ItemsSource="{Binding LogEntries}"
                                         Height="220"
                                         Background="{StaticResource CardBrush}"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- ── Panel 4: Performance ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="20,12" Margin="0,8,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="PERFORMANCE"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding WinLossDisplay}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4"
                                           Margin="20,0,8,0"
                                           Text="Session P&amp;L:"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="5"
                                           Text="{Binding TotalPnlDisplay}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{Binding TotalPnlBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════
                 TAB 2: Sniper Backtest
                 ══════════════════════════════════════════════════════ -->
            <TabItem Header="📊  Sniper Backtest">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20,24,8">

                        <TextBlock Text="📊  Sniper Backtest"
                                   Style="{StaticResource PageTitleStyle}"/>

                        <!-- ── Panel 1: Backtest Setup ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="20,14" Margin="0,12,0,0">
                            <StackPanel>

                                <TextBlock Text="SETUP" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,10"/>

                                <!-- Contract | From | To -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>    <!-- Contract -->
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>   <!-- "From:" -->
                                        <ColumnDefinition Width="120"/>    <!-- From date -->
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>   <!-- "To:" -->
                                        <ColumnDefinition Width="120"/>    <!-- To date -->
                                    </Grid.ColumnDefinitions>

                                    <controls:ContractSelectorControl
                                               Grid.Column="0"
                                               IsEnabled="{Binding IsNotBacktesting}"
                                               ContractId="{Binding BacktestContractId, Mode=TwoWay,
                                                           UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Column="2" Text="From:"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <DatePicker Grid.Column="3"
                                                SelectedDate="{Binding BacktestStartDate}"
                                                IsEnabled="{Binding IsNotBacktesting}"
                                                Background="{StaticResource CardBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"/>

                                    <TextBlock Grid.Column="5" Text="To:"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <DatePicker Grid.Column="6"
                                                SelectedDate="{Binding BacktestEndDate}"
                                                IsEnabled="{Binding IsNotBacktesting}"
                                                Background="{StaticResource CardBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"/>
                                </Grid>

                                <Border Height="8"/>

                                <!-- TP / SL for backtest -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="TP $ / SL $:"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox Text="{Binding BtInitialTpAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="44" IsEnabled="{Binding IsNotBacktesting}"
                                                 ToolTip="Initial take-profit in dollars (e.g. 20)"/>
                                        <TextBlock Text="/" VerticalAlignment="Center" Margin="5,0,5,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBox Text="{Binding BtInitialSlAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="44" IsEnabled="{Binding IsNotBacktesting}"
                                                 ToolTip="Initial stop-loss in dollars (e.g. 10)"/>
                                    </StackPanel>
                                </Grid>

                                <Border Height="10"/>

                                <!-- Run button and progress -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="▶  Run Backtest"
                                            Command="{Binding RunBacktestCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="140"/>

                                    <ProgressBar Grid.Column="2"
                                                 Value="{Binding BacktestProgress}"
                                                 Minimum="0" Maximum="100"
                                                 Height="6"
                                                 VerticalAlignment="Center"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Background="{StaticResource CardBrush}"
                                                 BorderThickness="0"
                                                 Visibility="{Binding IsBacktesting,
                                                             Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Panel 2: Results Summary ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="20,14" Margin="0,8,0,0"
                                Visibility="{Binding HasBacktestResults,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="RESULTS" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Trades -->
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding BtTotalTrades}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Trades"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Win % -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding BtWinRateDisplay}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Win Rate"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Net P&L -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding BtNetPnlDisplay}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{Binding BtPnlBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Net P&amp;L"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Max Drawdown -->
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding BtMaxDrawdownDisplay}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Max DD"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Avg P&L per trade -->
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding BtAvgPnlDisplay}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Avg/Trade"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Panel 3: Trade List ── -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="6" Padding="20,14" Margin="0,8,0,12"
                                Visibility="{Binding HasBacktestResults,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="TRADES" Style="{StaticResource SectionHeadingStyle}" Margin="0,0,0,10"/>

                                <DataGrid ItemsSource="{Binding BacktestTrades}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          MaxHeight="300"
                                          Background="{StaticResource CardBrush}"
                                          BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                                          RowBackground="{StaticResource CardBrush}"
                                          AlternatingRowBackground="{StaticResource SurfaceBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Entry" Binding="{Binding EntryTimeDisplay}" Width="90"/>
                                        <DataGridTextColumn Header="Side"  Binding="{Binding SideDisplay}"      Width="55"/>
                                        <DataGridTextColumn Header="Entry $" Binding="{Binding EntryPrice, StringFormat=F2}" Width="75"/>
                                        <DataGridTextColumn Header="Exit $"  Binding="{Binding ExitPrice, StringFormat=F2}"  Width="75"/>
                                        <DataGridTextColumn Header="Reason"  Binding="{Binding ExitReason}"     Width="60"/>
                                        <DataGridTextColumn Header="P&amp;L" Binding="{Binding PnLDisplay}"    Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ══════════════════════════════════════════════════════════
             BOTTOM: Live Sniper control bar (only for Tab 1)
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10"
                Visibility="{Binding IsLiveTabSelected,
                             Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="🎯  Start Sniper"
                        Command="{Binding StartCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="150"
                        IsEnabled="{Binding CanStart}"/>

                <Button Grid.Column="2"
                        Content="⏹  Stop"
                        Command="{Binding StopCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="90"
                        IsEnabled="{Binding IsRunning}"/>

                <TextBlock Grid.Column="4"
                           Text="{Binding FreeRideDisplay}"
                           VerticalAlignment="Center"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{Binding FreeRideBrush}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
