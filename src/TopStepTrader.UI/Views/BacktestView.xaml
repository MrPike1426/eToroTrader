<UserControl x:Class="TopStepTrader.UI.Views.BacktestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <TabControl Background="{StaticResource BackgroundBrush}">

        <!-- Tab 1: Run -->
        <TabItem Header="🔬  Run Backtest">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔬  Backtest Configuration"
                               Style="{StaticResource PageTitleStyle}"/>

                    <!-- Config form -->
                    <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="6" Padding="20,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Run Name:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RunName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Contract ID:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding ContractIdText, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Start Date:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DatePicker Grid.Row="2" Grid.Column="1"
                                        SelectedDate="{Binding StartDate}"
                                        Background="{StaticResource SurfaceBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Row="2" Grid.Column="3" Text="End Date:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DatePicker Grid.Row="2" Grid.Column="4"
                                        SelectedDate="{Binding EndDate}"
                                        Background="{StaticResource SurfaceBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Initial Capital:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding InitialCapital, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="4" Grid.Column="3" Text="Min Confidence:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="4" Grid.Column="4" Text="{Binding MinConfidence, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Stop Loss (ticks):" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding StopLossTicks, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="6" Grid.Column="3" Text="Take Profit (ticks):" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="6" Grid.Column="4" Text="{Binding TakeProfitTicks, UpdateSourceTrigger=PropertyChanged}"/>

                        </Grid>
                    </Border>

                    <!-- Progress & buttons -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button Content="▶  Run Backtest"
                                Command="{Binding RunCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="160"/>
                        <Button Content="■  Cancel"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                Margin="12,0,0,0" Width="80"/>
                        <Button Content="🧠  Train Model"
                                Command="{Binding TrainModelCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="24,0,0,0" Width="160"
                                ToolTip="Train / retrain the ML signal model using bar history from the database"/>
                        <TextBlock Text="{Binding ProgressText}"
                                   VerticalAlignment="Center" Margin="20,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>

                    <ProgressBar Grid.Row="6" Value="{Binding Progress}" Maximum="100"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Results summary -->
                    <Border Grid.Row="6" Background="{StaticResource CardBrush}"
                            CornerRadius="6" Padding="16,14"
                            Margin="0,40,0,0">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="TRADES" Style="{StaticResource SectionHeadingStyle}"/>
                                <TextBlock Text="{Binding TotalTrades}" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="WIN RATE" Style="{StaticResource SectionHeadingStyle}"/>
                                <TextBlock Text="{Binding WinRate}" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="TOTAL P&amp;L" Style="{StaticResource SectionHeadingStyle}"/>
                                <TextBlock Text="{Binding TotalPnL, StringFormat=C0}"
                                           Style="{StaticResource MetricValueStyle}"
                                           Foreground="{Binding PnLColor, Converter={StaticResource BrushKeyConverter}}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="MAX DRAWDOWN" Style="{StaticResource SectionHeadingStyle}"/>
                                <TextBlock Text="{Binding MaxDrawdown, StringFormat=C0}"
                                           Style="{StaticResource MetricValueStyle}"
                                           Foreground="{StaticResource SellBrush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="SHARPE" Style="{StaticResource SectionHeadingStyle}"/>
                                <TextBlock Text="{Binding Sharpe}" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="AVG P&amp;L / TRADE" Style="{StaticResource SectionHeadingStyle}"/>
                                <TextBlock Text="{Binding AvgPnL, StringFormat=C0}"
                                           Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Trade list -->
                    <DataGrid Grid.Row="8"
                              ItemsSource="{Binding Trades}"
                              IsReadOnly="True" Margin="0,0,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Entry Time"  Binding="{Binding EntryTime}"  Width="130"/>
                            <DataGridTextColumn Header="Exit Time"   Binding="{Binding ExitTime}"   Width="130"/>
                            <DataGridTextColumn Header="Side"        Binding="{Binding Side}"       Width="60"/>
                            <DataGridTextColumn Header="Entry"       Binding="{Binding EntryPrice}" Width="80"/>
                            <DataGridTextColumn Header="Exit"        Binding="{Binding ExitPrice}"  Width="80"/>
                            <DataGridTemplateColumn Header="P&amp;L" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PnL}"
                                                   Foreground="{Binding PnLColor, Converter={StaticResource BrushKeyConverter}}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Exit Reason" Binding="{Binding ExitReason}" Width="100"/>
                            <DataGridTextColumn Header="Confidence"  Binding="{Binding Confidence}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </ScrollViewer>
        </TabItem>

        <!-- Tab 2: History -->
        <TabItem Header="📁  Previous Runs">
            <Grid Margin="24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Previous Runs" Style="{StaticResource PageTitleStyle}" Margin="0"/>
                    <Button Content="↻ Refresh"
                            Command="{Binding LoadHistoryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="16,0,0,0" Padding="10,4" FontSize="11"/>
                </StackPanel>
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding PreviousRuns}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"         Binding="{Binding Id}"        Width="60"/>
                        <DataGridTextColumn Header="Name"       Binding="{Binding RunName}"   Width="180"/>
                        <DataGridTextColumn Header="Start"      Binding="{Binding StartDate}" Width="100"/>
                        <DataGridTextColumn Header="End"        Binding="{Binding EndDate}"   Width="100"/>
                        <DataGridTextColumn Header="Trades"     Binding="{Binding Trades}"    Width="70"/>
                        <DataGridTextColumn Header="Win Rate"   Binding="{Binding WinRate}"   Width="80"/>
                        <DataGridTextColumn Header="Total P&amp;L" Binding="{Binding TotalPnL}" Width="100"/>
                        <DataGridTextColumn Header="Sharpe"     Binding="{Binding Sharpe}"    Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>
