<UserControl x:Class="TopStepTrader.UI.Views.AiTradingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:TopStepTrader.UI.Controls"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <!--
        Layout: scrollable settings + log (top, fills all space) / control bar (bottom, auto height).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- settings panels + monitoring log -->
            <RowDefinition Height="Auto"/> <!-- control bar only -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TOP: Scrollable settings area
             ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">

                <TextBlock Text="⚡  AI-Assisted Trading"
                           Style="{StaticResource PageTitleStyle}"/>

                <!-- ── Panel 1: Account / Contract / Risk ───────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,12,0,0">
                    <StackPanel>

                        <!-- Row 1: Account ComboBox | Contract ComboBox | Contract ID TextBox -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>   <!-- "Account:" label -->
                                <ColumnDefinition Width="180"/>    <!-- Account ComboBox -->
                                <ColumnDefinition Width="16"/>     <!-- gap -->
                                <ColumnDefinition Width="220"/>    <!-- ContractSelectorControl -->
                                <ColumnDefinition Width="8"/>      <!-- gap -->
                                <ColumnDefinition Width="*"/>      <!-- Contract ID display -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Account:"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>

                            <!--  Account ComboBox — matches Dashboard "Select Account".
                                  VM defaults SelectedAccount to the PRACTICE account.  -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      FontSize="26"
                                      Style="{StaticResource UnclippedComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                      ToolTip="Select the combine account to trade with">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!--  Contract selector — self-contained; outputs long-form ID  -->
                            <controls:ContractSelectorControl
                                       Grid.Column="3"
                                       ContractId="{Binding SelectedContractId, Mode=TwoWay,
                                                   UpdateSourceTrigger=PropertyChanged}"/>

                            <!--  Read-only display of the long-form contract ID  -->
                            <TextBox Grid.Column="5"
                                     Text="{Binding SelectedContractId, Mode=OneWay}"
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"
                                     Background="{StaticResource CardBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Padding="6,4"
                                     ToolTip="Long-form contract ID passed to the trading engine"/>
                        </Grid>

                        <Border Height="8"/>

                        <!-- Row 2: Capital / Qty / TP / SL / Confidence — inline, squeezed to fit -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>   <!-- "Capital / Qty:" label -->
                                <ColumnDefinition Width="Auto"/>   <!-- Capital + Qty inputs -->
                                <ColumnDefinition Width="16"/>     <!-- gap -->
                                <ColumnDefinition Width="Auto"/>   <!-- "TP / SL:" label -->
                                <ColumnDefinition Width="Auto"/>   <!-- TP / SL inputs -->
                                <ColumnDefinition Width="16"/>     <!-- gap -->
                                <ColumnDefinition Width="Auto"/>   <!-- "Confidence %:" label -->
                                <ColumnDefinition Width="50"/>     <!-- Confidence threshold input -->
                                <ColumnDefinition Width="12"/>     <!-- gap -->
                                <ColumnDefinition Width="Auto"/>   <!-- Live confidence score -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Amount $ / Lvg:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Text="{Binding CapitalAtRisk, UpdateSourceTrigger=PropertyChanged}"
                                         Width="65" ToolTip="USD cash to invest per trade (clamped to min trade size: $1,000 / leverage for commodities)"/>
                                <TextBox Text="{Binding Leverage, UpdateSourceTrigger=PropertyChanged}"
                                         Width="36" Margin="6,0,0,0" ToolTip="Leverage (1 = no leverage). Min trade cash = $1,000 ÷ leverage for OIL/GOLD/Indices."/>
                            </StackPanel>

                            <TextBlock Grid.Column="3"
                                       Text="TP $ / SL $:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal">
                                <TextBox Text="{Binding InitialTpAmount, UpdateSourceTrigger=LostFocus}"
                                         Width="44" ToolTip="Initial take-profit in dollars (e.g. 20)"/>
                                <TextBlock Text="/" VerticalAlignment="Center" Margin="5,0,5,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding InitialSlAmount, UpdateSourceTrigger=LostFocus}"
                                         Width="44" ToolTip="Initial stop-loss in dollars (e.g. 10)"/>
                            </StackPanel>

                            <TextBlock Grid.Column="6"
                                       Text="Confidence %:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"
                                       ToolTip="Minimum weighted score 0–100 required to fire a signal"/>
                            <TextBox Grid.Column="7"
                                     Text="{Binding MinConfidencePct, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Default 75 — engine fires Long when UP ≥ this %, Short when DOWN ≥ this %"/>

                            <!-- Live EMA/RSI confidence score — updates every 30 seconds -->
                            <TextBlock Grid.Column="9"
                                       Text="{Binding LiveConfidenceText}"
                                       Foreground="{Binding LiveConfidenceColor}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       ToolTip="Live EMA/RSI signal score — dominant direction and strength, updated every 30 seconds"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ── Scale-In Configuration ──────────────────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,12" Margin="0,8,0,0"
                        BorderBrush="#FF4A9FFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- section label -->
                            <ColumnDefinition Width="20"/>    <!-- gap -->
                            <ColumnDefinition Width="Auto"/>  <!-- "Amount $:" label -->
                            <ColumnDefinition Width="70"/>    <!-- amount input -->
                            <ColumnDefinition Width="12"/>    <!-- gap -->
                            <ColumnDefinition Width="Auto"/>  <!-- "Lvg:" label -->
                            <ColumnDefinition Width="40"/>    <!-- leverage input -->
                            <ColumnDefinition Width="*"/>     <!-- description text -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="SCALE-IN"
                                   Style="{StaticResource SectionHeadingStyle}"
                                   VerticalAlignment="Center" Margin="0"/>

                        <TextBlock Grid.Column="2"
                                   Text="Amount $:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Column="3"
                                 Text="{Binding ScaleInAmount, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 ToolTip="Cash amount per scale-in trade (default $200). Max 3 scale-ins after initial entry, each requiring 3 consecutive extreme-confidence new bars."/>

                        <TextBlock Grid.Column="5"
                                   Text="Lvg:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,6,0"
                                   ToolTip="Leverage multiplier for scale-in trades (default 5)"/>
                        <TextBox Grid.Column="6"
                                 Text="{Binding ScaleInLeverage, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 ToolTip="Leverage applied to each scale-in order (default 5). Min trade cash = $1,000 ÷ leverage."/>

                        <TextBlock Grid.Column="7"
                                   Text="per trade · fires after 3 consecutive extreme-confidence new bars · max 3 additional trades"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <!-- ── Panel 2: Strategy Selection (1 active + 3 In Dev) ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,8,0,0">
                    <StackPanel>

                        <!-- Header: STRATEGY label + active strategy inline -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- "STRATEGY" -->
                                <ColumnDefinition Width="12"/>    <!-- gap -->
                                <ColumnDefinition Width="*"/>     <!-- active strategy text -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="STRATEGY"
                                       Style="{StaticResource SectionHeadingStyle}"
                                       VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ActiveStrategyText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Consolas" FontSize="10"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <!-- 4 strategy buttons (1 row) -->
                        <UniformGrid Columns="4" Margin="0,8,0,0">

                            <!-- 1. EMA/RSI Combined — ACTIVE -->
                            <Button Command="{Binding SelectEmaRsiCombinedCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-signal weighted EMA/RSI strategy. Fires Long/Short when score ≥ Confidence % threshold set above.">
                                <StackPanel>
                                    <TextBlock Text="🎯  EMA/RSI Combined"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="EMA21 · EMA50 · RSI14 weighted"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="5-min bars · user confidence %"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 2. Multi-Confluence Engine -->
                            <Button Command="{Binding SelectMultiConfluenceEngineCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="All 7 conditions must align: Ichimoku Cloud, EMA21, Tenkan/Kijun, Lagging Span, ADX &gt; 25 + DI, MACD histogram, StochRSI gate. SL = min(1.5×ATR, cloud edge); TP = 2:1 R:R. 15-min commodity bars.">
                                <StackPanel>
                                    <TextBlock Text="☁  Multi-Confluence"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Ichimoku · EMA · MACD · StochRSI · ADX"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="15-min bars · ATR dynamic SL/TP"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 3. LULT Divergence -->
                            <Button Command="{Binding SelectLultDivergenceCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-step momentum divergence (Market Cipher B): Anchor wave (WT ≷ ±60) → Trigger wave (shallower — reset if deeper) → price divergence → Green/Red Dot (WT1×WT2 cross) → engulfing candle. NQ 5-min bars · 07:00–11:00 EST · SL at trigger extreme · TP = 2R.">
                                <StackPanel>
                                    <TextBlock Text="🌊  LULT Divergence"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="WaveTrend · Anchor/Trigger · Divergence"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="5-min NQ bars · 2R · EST time filter"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 4. BB Squeeze Scalper -->
                            <Button Command="{Binding SelectBbSqueezeScalperCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0"
                                    ToolTip="Dual-mode BB scalper — Mode A: Squeeze Breakout (BBW &lt; SMA(BBW,20) for ≥3 bars then close breaks outer band, EMA5 slope + RSI7 confirm) · Mode B: Band Bounce (%B &lt; 0 or &gt; 1, RSI7 extreme, rejection wick ≥60%). TP=0.4% · SL=0.2% · 1-min bars · 5× leverage · 15s polling.">
                                <StackPanel>
                                    <TextBlock Text="📊  BB Squeeze Scalper"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="BB(12) · %B · RSI7 · EMA5 · ATR10"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="1-min bars · 0.4%/0.2% scalp · 5× lvg"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                        </UniformGrid>

                    </StackPanel>
                </Border>

                <!-- ── Panel 2b: Strategy Plain-English Summary ─────── -->
                <!--   Visible only after a strategy card has been selected.
                       Shows a Naked-Trader-style prose description of what the strategy
                       is waiting for, when all conditions are met, and when a trade fires. -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,8,0,0"
                        Visibility="{Binding StrategyDescriptionPanelVisible,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="WHAT THIS STRATEGY DOES"
                                   Style="{StaticResource SectionHeadingStyle}"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding StrategyNakedDescription, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 FontSize="12" Padding="10,8"
                                 Background="{StaticResource CardBrush}"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 ToolTip="Plain-English explanation of the selected strategy"/>
                    </StackPanel>
                </Border>

                <!-- ── Panel 3: Results (Confidence output + Trade History) ── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,8,0,8">
                    <StackPanel>

                        <TextBlock Text="RESULTS"
                                   Style="{StaticResource SectionHeadingStyle}"
                                   Margin="0,0,0,8"/>

                        <!-- Loading indicator while confidence check is running -->
                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,6"
                                     Visibility="{Binding IsCheckingConfidence, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Confidence output: visible once a check has been run -->
                        <TextBox Text="{Binding ConfidenceText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                 FontSize="14" Margin="0,0,0,10"
                                 Background="{StaticResource CardBrush}"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Visibility="{Binding HasConfidenceResult, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Trade history: visible once trades are placed this session -->
                        <StackPanel Visibility="{Binding HasTradeRows, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="TRADE HISTORY"
                                       Style="{StaticResource SectionHeadingStyle}"
                                       FontSize="9" Margin="0,0,0,4"/>
                            <DataGrid ItemsSource="{Binding TradeRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserSortColumns="False"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                                      VerticalGridLinesBrush="{StaticResource BorderBrush}"
                                      MaxHeight="173"
                                      Background="{StaticResource CardBrush}"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#0AFFFFFF"
                                      BorderThickness="1"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      FontFamily="Consolas" FontSize="11"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"      Value="{StaticResource SidebarBrush}"/>
                                        <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="FontSize"        Value="11"/>
                                        <Setter Property="FontWeight"      Value="Bold"/>
                                        <Setter Property="Padding"         Value="4,5"/>
                                        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="SeparatorBrush"  Value="{StaticResource BorderBrush}"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background"        Value="Transparent"/>
                                        <Setter Property="BorderThickness"   Value="0"/>
                                        <Setter Property="Padding"           Value="4,2"/>
                                        <Setter Property="Foreground"        Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="FontSize"          Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding EntryTimeDisplay}" Width="80"/>
                                    <DataGridTextColumn Header="Contract" Binding="{Binding ContractDisplay}" Width="80"/>
                                    <DataGridTextColumn Header="Conf %" Binding="{Binding ConfidencePct, StringFormat={}{0}%}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Side" Binding="{Binding SideDisplay}" Width="50"/>
                                    <DataGridTextColumn Header="TX Order" Binding="{Binding TradeIdDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="eToro ID" Binding="{Binding EtoroPositionIdDisplay}" Width="85"/>
                                    <DataGridTextColumn Header="Opened" Binding="{Binding OpenedAtDisplay}" Width="80"/>
                                    <DataGridTextColumn Header="Exposure" Binding="{Binding ExposureDisplay}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="P&amp;L" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PnlDisplay}"
                                                           Foreground="{Binding PnlForeground}"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Result" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="8" Height="8" Fill="#FF8C00"
                                                             Margin="0,0,5,0" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInProgress}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard x:Name="PulseSB">
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="1.0" To="0.15" Duration="0:0:0.8"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <StopStoryboard BeginStoryboardName="PulseSB"/>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Result}" Foreground="{Binding ResultForeground}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                        <!-- Placeholder: shown until confidence check or first trade -->
                        <TextBlock Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Text="Results will appear here after running Check Confidence or placing trades."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" FontStyle="Italic"/>

                    </StackPanel>
                </Border>

                    <!-- ── Monitoring Log ──────────────────────────────────────────── -->
                    <Border Background="{StaticResource SidebarBrush}"
                            CornerRadius="6" Margin="0,0,0,8" Height="200">
                        <ListBox x:Name="LogList"
                                 ItemsSource="{Binding LogEntries}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Margin="24,6,24,6"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 SelectionMode="Single">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"                   Value="0,1"/>
                                    <Setter Property="Foreground"                Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Background"                Value="Transparent"/>
                                    <Setter Property="BorderThickness"           Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle"          Value="{x:Null}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="Consolas" FontSize="10"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        <!-- ══════════════════════════════════════════════════════════
             BOTTOM: Control bar only
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- control bar -->
            </Grid.RowDefinitions>

            <!-- Control bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    Padding="24,8"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource CardBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- Start -->
                        <ColumnDefinition Width="Auto"/>  <!-- Stop -->
                        <ColumnDefinition Width="20"/>   <!-- spacer -->
                        <ColumnDefinition Width="Auto"/>  <!-- Check Confidence -->
                        <ColumnDefinition Width="Auto"/>  <!-- hint label -->
                        <ColumnDefinition Width="*"/>     <!-- Status (right fill) -->
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="▶  Start Monitoring"
                            Command="{Binding StartCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="160"
                            IsEnabled="{Binding IsNotRunning}"
                            ToolTip="Start the strategy execution engine"/>
                    <Button Grid.Column="1"
                            Content="■  Stop"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Margin="10,0,0,0" Width="70"
                            ToolTip="Stop the running strategy"/>
                    <Button Grid.Column="3"
                            Content="🔍  Check Confidence"
                            Command="{Binding GetConfidenceCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,4" FontSize="11"
                            ToolTip="Ask Claude Haiku for market context and sentiment on the selected contract"/>
                    <TextBlock Grid.Column="4"
                               Text="Ask Claude for market context on the selected contract"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="5"
                               Text="{Binding StatusText}"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="16,0,0,0"/>
                </Grid>
            </Border>

                    </Grid>
                </Grid>

            </UserControl>
