<UserControl x:Class="TopStepTrader.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20" MaxWidth="900" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="⚙️  Settings" Style="{StaticResource PageTitleStyle}"/>

            <!-- Auto-Execution (Moved to TOP) -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="20,16"
                    BorderBrush="{StaticResource HaltedBrush}"
                    BorderThickness="{Binding AutoExecutionEnabled, Converter={StaticResource BoolToBorderThicknessConverter}}">
                <StackPanel>
                    <TextBlock Text="AUTO-EXECUTION" Style="{StaticResource SectionHeadingStyle}"
                               Foreground="{StaticResource HaltedBrush}"/>
                    <TextBlock Text="⚠  When enabled, the AI will automatically place real orders on live accounts."
                               Foreground="{StaticResource WarningBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <CheckBox Content="Enable Autonomous Order Execution"
                              IsChecked="{Binding AutoExecutionEnabled}"
                              Foreground="{StaticResource HaltedBrush}"
                              FontWeight="SemiBold" FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Risk Settings (Condensed to ONE LINE) -->
            <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="RISK GUARD SETTINGS" Style="{StaticResource SectionHeadingStyle}"/>
                    <TextBlock Text="Changes apply immediately for the current session. Edit appsettings.json for persistence."
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- Single row with three fields -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <!-- Daily Loss Limit -->
                        <StackPanel Width="200" Margin="0,0,16,0">
                            <TextBlock Text="Daily Loss Limit ($):"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding DailyLossLimit, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32"/>
                        </StackPanel>

                        <!-- Max Position -->
                        <StackPanel Width="200" Margin="0,0,16,0">
                            <TextBlock Text="Max Position (contracts):"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MaxPosition, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32"/>
                        </StackPanel>

                        <!-- Min Signal Confidence -->
                        <StackPanel Width="200" Margin="0,0,16,0">
                            <TextBlock Text="Min Signal Confidence (0-1):"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MinConfidence, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32"/>
                        </StackPanel>

                        <!-- Apply Button (inline) -->
                        <StackPanel VerticalAlignment="Bottom">
                            <Button Content="Apply"
                                    Command="{Binding ApplyRiskCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="20,8"
                                    Height="32"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- API Status (MOVED TO BOTTOM - Condensed) -->
            <Border Grid.Row="6" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="6" Padding="20,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="API Status:" Foreground="{StaticResource TextSecondaryBrush}" Width="100" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding ConnectionStatusText}"
                                   Foreground="{Binding ConnectionStatusColor, Converter={StaticResource BrushKeyConverter}}"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="Reconnect / Refresh Token"
                                Command="{Binding ConnectCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,4"
                                FontSize="11"
                                Height="28"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Grid.Row="8"
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"/>

        </Grid>
    </ScrollViewer>
</UserControl>
