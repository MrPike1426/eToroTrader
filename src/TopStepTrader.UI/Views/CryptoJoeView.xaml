<UserControl x:Class="TopStepTrader.UI.Views.CryptoJoeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <!--
        Layout: scrollable settings + asset boxes + log (top, fills all space)
                control bar (bottom, auto height).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- settings panels + asset boxes + log -->
            <RowDefinition Height="Auto"/> <!-- control bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TOP: Scrollable settings area
             ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">

                <TextBlock Text="☕  CryptoJoe"
                           Style="{StaticResource PageTitleStyle}"/>

                <!-- ── Panel 1: Account / Risk ──────────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,12,0,0">
                    <StackPanel>

                        <!-- Row 1: Account ComboBox | Monitoring label -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- "Account:" label -->
                                <ColumnDefinition Width="180"/>   <!-- Account ComboBox -->
                                <ColumnDefinition Width="16"/>    <!-- gap -->
                                <ColumnDefinition Width="*"/>     <!-- Monitoring label -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Account:"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      FontSize="26"
                                      Style="{StaticResource UnclippedComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                      ToolTip="Select the combine account to trade with">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Monitoring label — exact text per spec -->
                            <TextBlock Grid.Column="3"
                                       Text="Monitoring...  BTC  |  ETH  |  XRP  |  SOL  |  BNB"
                                       Foreground="{StaticResource TextHeaderBrush}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="CryptoJoe monitors all 5 crypto assets simultaneously, 24/7"/>
                        </Grid>

                        <Border Height="8"/>

                        <!-- 5 inline asset icon labels -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">

                            <Border Background="{StaticResource CardBrush}"
                                    CornerRadius="4" Padding="9,4" Margin="0,0,4,0">
                                <TextBlock FontWeight="SemiBold" FontSize="12">
                                    <Run Text="₿"/><Run Text="  BTC"/>
                                </TextBlock>
                            </Border>

                            <TextBlock Text="|" VerticalAlignment="Center" Margin="2,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>

                            <Border Background="{StaticResource CardBrush}"
                                    CornerRadius="4" Padding="9,4" Margin="4,0,4,0">
                                <TextBlock FontWeight="SemiBold" FontSize="12">
                                    <Run Text="Ξ"/><Run Text="  ETH"/>
                                </TextBlock>
                            </Border>

                            <TextBlock Text="|" VerticalAlignment="Center" Margin="2,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>

                            <Border Background="{StaticResource CardBrush}"
                                    CornerRadius="4" Padding="9,4" Margin="4,0,4,0">
                                <TextBlock FontWeight="SemiBold" FontSize="12">
                                    <Run Text="✕"/><Run Text="  XRP"/>
                                </TextBlock>
                            </Border>

                            <TextBlock Text="|" VerticalAlignment="Center" Margin="2,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>

                            <Border Background="{StaticResource CardBrush}"
                                    CornerRadius="4" Padding="9,4" Margin="4,0,4,0">
                                <TextBlock FontWeight="SemiBold" FontSize="12">
                                    <Run Text="◎"/><Run Text="  SOL"/>
                                </TextBlock>
                            </Border>

                            <TextBlock Text="|" VerticalAlignment="Center" Margin="2,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>

                            <Border Background="{StaticResource CardBrush}"
                                    CornerRadius="4" Padding="9,4" Margin="4,0,0,0">
                                <TextBlock FontWeight="SemiBold" FontSize="12">
                                    <Run Text="◈"/><Run Text="  BNB"/>
                                </TextBlock>
                            </Border>

                        </StackPanel>

                        <!-- Row 2: Amount / Leverage | TP / SL | Confidence -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- "Amount $ / Lvg:" label -->
                                <ColumnDefinition Width="Auto"/>  <!-- Amount + Leverage inputs -->
                                <ColumnDefinition Width="16"/>    <!-- gap -->
                                <ColumnDefinition Width="Auto"/>  <!-- "TP% / SL%:" label -->
                                <ColumnDefinition Width="Auto"/>  <!-- TP / SL inputs -->
                                <ColumnDefinition Width="16"/>    <!-- gap -->
                                <ColumnDefinition Width="Auto"/>  <!-- "Confidence %:" label -->
                                <ColumnDefinition Width="50"/>    <!-- Confidence input -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Amount $ / Lvg:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Text="{Binding CapitalAtRisk, UpdateSourceTrigger=PropertyChanged}"
                                         Width="65" ToolTip="USD cash to invest per trade"/>
                                <TextBox Text="{Binding Leverage, UpdateSourceTrigger=PropertyChanged}"
                                         Width="36" Margin="6,0,0,0" ToolTip="Leverage multiplier"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3"
                                       Text="TP $ / SL $:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal">
                                <TextBox Text="{Binding InitialTpAmount, UpdateSourceTrigger=LostFocus}"
                                         Width="44" ToolTip="Initial take-profit in dollars (e.g. 20)"/>
                                <TextBlock Text="/" VerticalAlignment="Center" Margin="5,0,5,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding InitialSlAmount, UpdateSourceTrigger=LostFocus}"
                                         Width="44" ToolTip="Initial stop-loss in dollars (e.g. 10)"/>
                            </StackPanel>

                            <TextBlock Grid.Column="6"
                                       Text="Confidence %:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"
                                       ToolTip="Minimum weighted score 0–100 required to fire a signal across all 5 assets"/>
                            <TextBox Grid.Column="7"
                                     Text="{Binding MinConfidencePct, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Default 85 — fires Long when UP ≥ this %, Short when DOWN ≥ this %"/>

                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ── Panel 2: Strategy Selection ──────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,8,0,0">
                    <StackPanel>

                        <!-- Header: STRATEGY label + active strategy inline -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- "STRATEGY" -->
                                <ColumnDefinition Width="12"/>    <!-- gap -->
                                <ColumnDefinition Width="*"/>     <!-- active strategy text -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="STRATEGY"
                                       Style="{StaticResource SectionHeadingStyle}"
                                       VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ActiveStrategyText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Consolas" FontSize="10"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <!-- 4 strategy buttons — EMA/RSI Combined active, 3 disabled -->
                        <UniformGrid Columns="4" Margin="0,8,0,0">

                            <!-- 1. EMA/RSI Combined — ACTIVE -->
                            <Button Command="{Binding SelectEmaRsiCombinedCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-signal weighted EMA/RSI strategy applied to all 5 crypto assets concurrently. Fires Long/Short when score ≥ Confidence % threshold.">
                                <StackPanel>
                                    <TextBlock Text="🎯  EMA/RSI Combined"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="EMA21 · EMA50 · RSI14 weighted"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="5-min bars · user confidence %"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 2. Multi-Confluence Engine — ACTIVE -->
                            <Button Command="{Binding SelectMultiConfluenceEngineCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="All 7 conditions must align: Ichimoku Cloud, EMA21, Tenkan/Kijun, Lagging Span, ADX &gt; 25 + DI, MACD histogram, StochRSI gate. SL = min(1.5×ATR, cloud edge); TP = 2:1 R:R. 15-min crypto bars.">
                                <StackPanel>
                                    <TextBlock Text="☁  Multi-Confluence"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Ichimoku · EMA · MACD · StochRSI · ADX"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="15-min bars · ATR dynamic SL/TP"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 3. LULT Divergence -->
                            <Button Command="{Binding SelectLultDivergenceCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-step momentum divergence (Market Cipher B simulation): Anchor wave (WT ≷ ±60) → Trigger wave (shallower — reset if deeper) → price divergence → Green/Red Dot (WT1×WT2 cross) → engulfing candle. BTC 5-min bars · 07:00–11:00 EST · SL at trigger extreme · TP = 2R.">
                                <StackPanel>
                                    <TextBlock Text="🌊  LULT Divergence"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="WaveTrend · Anchor/Trigger · Divergence"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="5-min crypto bars · 2R · EST time filter"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 4. BB Squeeze Scalper -->
                            <Button Command="{Binding SelectBbSqueezeScalperCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0"
                                    ToolTip="Dual-mode BB scalper — Mode A: Squeeze Breakout (BBW &lt; SMA(BBW,20) for ≥3 bars then close breaks outer band, EMA5 slope + RSI7 confirm) · Mode B: Band Bounce (%B &lt; 0 or &gt; 1, RSI7 extreme, rejection wick ≥60%). TP=0.4% · SL=0.2% · 1-min bars · 5× leverage · 15s polling.">
                                <StackPanel>
                                    <TextBlock Text="📊  BB Squeeze Scalper"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="BB(12) · %B · RSI7 · EMA5 · ATR10"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="1-min bars · 0.4%/0.2% scalp · 5× lvg"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                        </UniformGrid>

                    </StackPanel>
                </Border>

                <!-- ── Panel 3: Asset Status — 5 column cards ──────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,8,0,0">
                    <StackPanel>

                        <TextBlock Text="ASSET STATUS"
                                   Style="{StaticResource SectionHeadingStyle}"
                                   Margin="0,0,0,8"/>

                        <!-- 5 equal-width columns, one per asset -->
                        <ItemsControl ItemsSource="{Binding Assets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Top-accent card — colour driven by ConfidenceColor -->
                                    <Border Background="{Binding TileBackground}"
                                            CornerRadius="6"
                                            Margin="0,0,6,0"
                                            BorderThickness="0,3,0,0"
                                            BorderBrush="{Binding ConfidenceColor}">
                                        <StackPanel Margin="12,14,12,14"
                                                    HorizontalAlignment="Center">

                                            <!-- Large icon -->
                                            <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                       FontSize="26"
                                                       HorizontalAlignment="Center"/>

                                            <!-- Symbol name -->
                                            <TextBlock Text="{Binding Symbol, Mode=OneWay}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>

                                            <!-- Market OPEN / CLOSED badge -->
                                            <TextBlock Text="{Binding AssetStatusText}"
                                                       Foreground="{Binding StatusForeground}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,3,0,0"/>

                                            <!-- Divider -->
                                            <Border Height="1"
                                                    Background="{StaticResource BorderBrush}"
                                                    Margin="0,10,0,10"/>

                                            <!-- Direction + confidence summary -->
                                            <TextBlock Text="{Binding SummaryLine}"
                                                       Foreground="{Binding ConfidenceColor}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"/>

                                            <!-- Last-updated timestamp -->
                                            <TextBlock Text="{Binding LastUpdated}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,8,0,0"/>


                                            <!-- Live position / trail bracket status -->
                                            <TextBlock Text="{Binding TradeStatusLine}"
                                                       FontFamily="Consolas"
                                                       FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Margin="0,5,0,0"
                                                       ToolTip="Live position status. Trail bracket arms at 2pct profit."/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- ── Monitoring Log ──────────────────────────────────── -->
                <Border Background="{StaticResource SidebarBrush}"
                        CornerRadius="6" Margin="0,8,0,8" Height="180">
                    <ListBox x:Name="LogList"
                             ItemsSource="{Binding LogEntries}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="24,6,24,6"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"                    Value="0,1"/>
                                <Setter Property="Foreground"                 Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Background"                 Value="Transparent"/>
                                <Setter Property="BorderThickness"            Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="Consolas" FontSize="10"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════════════════════
             BOTTOM: Control bar
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,8"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource CardBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Start -->
                    <ColumnDefinition Width="Auto"/>  <!-- Stop -->
                    <ColumnDefinition Width="*"/>     <!-- Status (right fill) -->
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="▶  Start Monitoring"
                        Command="{Binding StartCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="160"
                        IsEnabled="{Binding IsNotRunning}"
                        ToolTip="Start all 5 crypto asset monitoring sessions concurrently"/>

                <Button Grid.Column="1"
                        Content="■  Stop All"
                        Command="{Binding StopCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="10,0,0,0" Width="80"
                        ToolTip="Stop all 5 running crypto asset sessions"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
