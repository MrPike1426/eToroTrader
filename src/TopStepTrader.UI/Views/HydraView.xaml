<UserControl x:Class="TopStepTrader.UI.Views.HydraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <!--
        Layout: scrollable settings + asset boxes + log (top, fills all space)
                control bar (bottom, auto height).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- settings panels -->
            <RowDefinition Height="*"/>     <!-- log fills remaining space -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TOP: Scrollable settings area
             ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">

                <TextBlock Text="🐙  Hydra Monitoring"
                           Style="{StaticResource PageTitleStyle}"/>

                <!-- ── Panel 1: Account / Risk ──────────────────────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,12,0,0">
                    <StackPanel>

                        <!-- Row 1: Account ComboBox | Monitoring label | Start / Stop -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- "Account:" label -->
                                <ColumnDefinition Width="180"/>   <!-- Account ComboBox -->
                                <ColumnDefinition Width="16"/>    <!-- gap -->
                                <ColumnDefinition Width="*"/>     <!-- Monitoring label -->
                                <ColumnDefinition Width="16"/>    <!-- gap -->
                                <ColumnDefinition Width="Auto"/>  <!-- Start button -->
                                <ColumnDefinition Width="10"/>    <!-- gap -->
                                <ColumnDefinition Width="Auto"/>  <!-- Stop button -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Account:"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      FontSize="26"
                                      Style="{StaticResource UnclippedComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                      ToolTip="Select the combine account to trade with">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Monitoring label — exact text per spec -->
                            <TextBlock Grid.Column="3"
                                       Text="Monitoring...  OIL  |  GOLD  |  NASDAQ  |  SPX 500  |  UK100"
                                       Foreground="{StaticResource TextHeaderBrush}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="Hydra monitors all 5 assets simultaneously, 24/7"/>

                            <Button Grid.Column="5"
                                    Content="▶  Start Monitoring"
                                    Command="{Binding StartCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="160"
                                    IsEnabled="{Binding IsNotRunning}"
                                    ToolTip="Start all 5 asset monitoring sessions concurrently"/>

                            <Button Grid.Column="7"
                                    Content="■  Stop All"
                                    Command="{Binding StopCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Width="80"
                                    ToolTip="Stop all 5 running asset sessions"/>
                        </Grid>

                        <!-- Status: running state + last updated, shown under the buttons -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,4,0,4">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LastUpdatedDisplay}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Row 2: Amount / Leverage | TP / SL | Confidence -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- "Amount $ / Lvg:" label -->
                                <ColumnDefinition Width="Auto"/>  <!-- Amount + Leverage inputs -->
                                <ColumnDefinition Width="16"/>    <!-- gap -->
                                <ColumnDefinition Width="Auto"/>  <!-- "TP% / SL%:" label -->
                                <ColumnDefinition Width="Auto"/>  <!-- TP / SL inputs -->
                                <ColumnDefinition Width="16"/>    <!-- gap -->
                                <ColumnDefinition Width="Auto"/>  <!-- "Confidence %:" label -->
                                <ColumnDefinition Width="50"/>    <!-- Confidence input -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Amount $ / Lvg:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Text="{Binding CapitalAtRisk, UpdateSourceTrigger=PropertyChanged}"
                                         Width="65" ToolTip="USD cash to invest per trade"/>
                                <TextBox Text="{Binding Leverage, UpdateSourceTrigger=PropertyChanged}"
                                         Width="36" Margin="6,0,0,0" ToolTip="Leverage multiplier"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3"
                                       Text="TP $ / SL $:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal">
                                <TextBox Text="{Binding InitialTpAmount, UpdateSourceTrigger=LostFocus}"
                                         Width="44" ToolTip="Initial take-profit in dollars (e.g. 20)"/>
                                <TextBlock Text="/" VerticalAlignment="Center" Margin="5,0,5,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding InitialSlAmount, UpdateSourceTrigger=LostFocus}"
                                         Width="44" ToolTip="Initial stop-loss in dollars (e.g. 10)"/>
                            </StackPanel>

                            <TextBlock Grid.Column="6"
                                       Text="Confidence %:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0"
                                       ToolTip="Minimum weighted score 0–100 required to fire a signal across all 5 assets"/>
                            <TextBox Grid.Column="7"
                                     Text="{Binding MinConfidencePct, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Default 85 — fires Long when UP ≥ this %, Short when DOWN ≥ this %"/>

                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ── Panel 2: Strategy Selection ──────────────────── -->
                <!-- Collapses once monitoring starts; reappears when stopped -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,8,0,0"
                        Visibility="{Binding IsNotRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>

                        <!-- Header: STRATEGY label + active strategy inline -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- "STRATEGY" -->
                                <ColumnDefinition Width="12"/>    <!-- gap -->
                                <ColumnDefinition Width="*"/>     <!-- active strategy text -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="STRATEGY"
                                       Style="{StaticResource SectionHeadingStyle}"
                                       VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ActiveStrategyText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Consolas" FontSize="10"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <!-- 4 strategy buttons — EMA/RSI Combined active, 3 disabled -->
                        <UniformGrid Columns="4" Margin="0,8,0,0">

                            <!-- 1. EMA/RSI Combined — ACTIVE -->
                            <Button Command="{Binding SelectEmaRsiCombinedCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-signal weighted EMA/RSI strategy applied to all 5 assets concurrently. Fires Long/Short when score ≥ Confidence % threshold.">
                                <StackPanel>
                                    <TextBlock Text="🎯  EMA/RSI Combined"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="EMA21 · EMA50 · RSI14 weighted"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="5-min bars · user confidence %"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 2. Multi-Confluence Engine — ACTIVE -->
                            <Button Command="{Binding SelectMultiConfluenceEngineCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="All 7 conditions must align: Ichimoku Cloud, EMA21, Tenkan/Kijun, Lagging Span, ADX &gt; 25 + DI, MACD histogram, StochRSI gate. SL = min(1.5×ATR, cloud edge); TP = 2:1 R:R. 15-min commodity bars.">
                                <StackPanel>
                                    <TextBlock Text="☁  Multi-Confluence"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Ichimoku · EMA · MACD · StochRSI · ADX"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="15-min bars · ATR dynamic SL/TP"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 3. LULT Divergence -->
                            <Button Command="{Binding SelectLultDivergenceCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0,0,6,0"
                                    ToolTip="6-step momentum divergence (Market Cipher B simulation): Anchor wave (WT ≷ ±60) → Trigger wave (shallower — reset if deeper) → price divergence → Green/Red Dot (WT1×WT2 cross) → engulfing candle. NQ 5-min bars · 07:00–11:00 EST · SL at trigger extreme · TP = 2R.">
                                <StackPanel>
                                    <TextBlock Text="🌊  LULT Divergence"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="WaveTrend · Anchor/Trigger · Divergence"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="5-min NQ bars · 2R · EST time filter"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                            <!-- 4. BB Squeeze Scalper -->
                            <Button Command="{Binding SelectBbSqueezeScalperCommand}"
                                    Style="{StaticResource StrategyCardStyle}"
                                    Margin="0"
                                    ToolTip="Dual-mode BB scalper — Mode A: Squeeze Breakout (BBW &lt; SMA(BBW,20) for ≥3 bars then close breaks outer band, EMA5 slope + RSI7 confirm) · Mode B: Band Bounce (%B &lt; 0 or &gt; 1, RSI7 extreme, rejection wick ≥60%). TP=0.4% · SL=0.2% · 1-min bars · 5× leverage · 15s polling.">
                                <StackPanel>
                                    <TextBlock Text="📊  BB Squeeze Scalper"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="BB(12) · %B · RSI7 · EMA5 · ATR10"
                                               FontSize="10" Margin="0,2,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="1-min bars · 0.4%/0.2% scalp · 5× lvg"
                                               FontSize="9" Margin="0,1,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Button>

                        </UniformGrid>

                    </StackPanel>
                </Border>

                <!-- ── Panel 3: Asset Status — 5 column cards ──────── -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6" Padding="20,14" Margin="0,8,0,0">
                    <StackPanel>

                        <TextBlock Text="ASSET STATUS"
                                   Style="{StaticResource SectionHeadingStyle}"
                                   Margin="0,0,0,8"/>

                        <!-- 5 equal-width columns, one per asset -->
                        <ItemsControl ItemsSource="{Binding Assets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Top-accent card — green when open, red when closed -->
                                    <Border Background="{StaticResource CardBrush}"
                                            CornerRadius="6"
                                            Margin="0,0,6,0"
                                            BorderThickness="0,3,0,0"
                                            BorderBrush="{Binding StatusBorderBrush}">
                                        <!-- FontSize=10 cascades to all text; ForestGreen cascades when tradeable -->
                                        <StackPanel Margin="12,14,12,14"
                                                    HorizontalAlignment="Center"
                                                    TextElement.FontSize="10"
                                                    TextElement.Foreground="{Binding CardForeground}">

                                            <!-- Icon + Symbol name inline, both FontSize=26 -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Icon, Mode=OneWay}"
                                                           FontSize="26"/>
                                                <TextBlock Text="{Binding Symbol, Mode=OneWay}"
                                                           FontSize="26"
                                                           FontWeight="SemiBold"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>

                                            <!-- Divider -->
                                            <Border Height="1"
                                                    Background="{StaticResource BorderBrush}"
                                                    Margin="0,10,0,10"/>

                                            <!-- Direction + confidence summary -->
                                            <TextBlock Text="{Binding SummaryLine}"
                                                       Foreground="{Binding DirectionForeground}"
                                                       FontFamily="Consolas"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"/>

                                            <!-- ADX value | 5-min price change (single row) -->
                                            <TextBlock Text="{Binding AdxLineDisplay}"
                                                       FontFamily="Consolas"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,6,0,0"/>

                                            <!-- Live position / trail bracket status -->
                                            <TextBlock Text="{Binding TradeStatusLine}"
                                                       FontFamily="Consolas"
                                                       FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Margin="0,5,0,0"
                                                       ToolTip="Live position status: entry price, size, and unrealised P&amp;L. Updates every 30 s. Trail bracket arms at ≥2% profit."/>

                                            <!-- Turtle bracket confirmation -->
                                            <TextBlock Text="{Binding TurtleStatusLine}"
                                                       FontFamily="Consolas"
                                                       FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="#FFFF9500"
                                                       Margin="0,3,0,0"
                                                       Visibility="{Binding HasTurtleStatus, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── Indicator Grid — one live row per asset ─────────────────────── -->
                        <Border Grid.Row="1"
                                Background="{StaticResource SidebarBrush}"
                                CornerRadius="6" Margin="24,4,24,8" Padding="8,6">
                            <Grid>

                                <!-- ══ EMA/RSI Combined Grid ══════════════════════════════════════════ -->
                                <DataGrid ItemsSource="{Binding Assets}"
                                          Visibility="{Binding IsEmaRsiActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="False"
                                          CanUserResizeRows="False"
                                          RowHeight="64"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FontFamily="Consolas" FontSize="12"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="#FF1A2845"/>
                                            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                                            <Setter Property="FontSize"        Value="9"/>
                                            <Setter Property="FontWeight"      Value="SemiBold"/>
                                            <Setter Property="Padding"         Value="6,5"/>
                                            <Setter Property="BorderBrush"     Value="#FF2E3F6E"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background"               Value="Transparent"/>
                                            <Setter Property="BorderThickness"          Value="0"/>
                                            <Setter Property="Padding"                  Value="0"/>
                                            <Setter Property="Foreground"               Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A4A9FFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <!-- Asset -->
                                        <DataGridTextColumn Header="Asset"  Binding="{Binding Symbol}"      Width="60"/>
                                        <!-- Time -->
                                        <DataGridTextColumn Header="Time"   Binding="{Binding LastUpdated}" Width="72"/>
                                        <!-- Close -->
                                        <DataGridTextColumn Header="Close"  Binding="{Binding GridClose}"   Width="76"/>
                                        <!-- EMA21 / EMA50 (stacked) -->
                                        <DataGridTemplateColumn Header="EMA21&#x0A;EMA50" Width="82">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridEma21}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridEma50}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- RSI14 -->
                                        <DataGridTextColumn Header="RSI14"  Binding="{Binding GridRsi14}"   Width="55"/>
                                        <!-- ADX -->
                                        <DataGridTextColumn Header="ADX"    Binding="{Binding GridAdx}"     Width="50"/>
                                        <!-- DI+ / DI- (stacked, colour coded) -->
                                        <DataGridTemplateColumn Header="DI+&#x0A;DI-" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridDiPlus}"  FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource BuyBrush}"/>
                                                        <TextBlock Text="{Binding GridDiMinus}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource SellBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Bull% / Bear% (stacked) -->
                                        <DataGridTemplateColumn Header="Bull%&#x0A;Bear%" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding UpPct,   StringFormat='{}{0}%'}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource BuyBrush}"/>
                                                        <TextBlock Text="{Binding DownPct, StringFormat='{}{0}%'}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource SellBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Conf -->
                                        <DataGridTextColumn Header="Conf"   Binding="{Binding GridConf}"    Width="90"/>
                                        <!-- Explain -->
                                        <DataGridTemplateColumn Header="Explain" Width="*" MinWidth="260">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding GridExplain}"
                                                               FontFamily="Consolas" FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="6,4"
                                                               VerticalAlignment="Top"
                                                               ToolTip="{Binding GridExplain}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- ══ Multi-Confluence Grid ═══════════════════════════════════════════ -->
                                <DataGrid ItemsSource="{Binding Assets}"
                                          Visibility="{Binding IsMultiConfluenceActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="False"
                                          CanUserResizeRows="False"
                                          RowHeight="64"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FontFamily="Consolas" FontSize="12"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="#FF1A2845"/>
                                            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                                            <Setter Property="FontSize"        Value="9"/>
                                            <Setter Property="FontWeight"      Value="SemiBold"/>
                                            <Setter Property="Padding"         Value="6,5"/>
                                            <Setter Property="BorderBrush"     Value="#FF2E3F6E"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background"               Value="Transparent"/>
                                            <Setter Property="BorderThickness"          Value="0"/>
                                            <Setter Property="Padding"                  Value="0"/>
                                            <Setter Property="Foreground"               Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A4A9FFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <!-- Asset -->
                                        <DataGridTextColumn Header="Asset"  Binding="{Binding Symbol}"      Width="60"/>
                                        <!-- Time -->
                                        <DataGridTextColumn Header="Time"   Binding="{Binding LastUpdated}" Width="72"/>
                                        <!-- Close -->
                                        <DataGridTextColumn Header="Close"  Binding="{Binding GridClose}"   Width="76"/>
                                        <!-- Cloud1 / Cloud2 (stacked) -->
                                        <DataGridTemplateColumn Header="Cloud1&#x0A;Cloud 2" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridCloud1}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridCloud2}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- T: / K: (stacked) -->
                                        <DataGridTemplateColumn Header="Tenkan:&#x0A;Kijun:" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridTenkan}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridKijun}"  FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- EMA21: / EMA50: (stacked) -->
                                        <DataGridTemplateColumn Header="EMA21:&#x0A;EMA50:" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridEma21}" FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridEma50}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- ADX -->
                                        <DataGridTextColumn Header="ADX:"  Binding="{Binding GridAdx}"   Width="50"/>
                                        <!-- DI+ / DI- (stacked, colour coded) -->
                                        <DataGridTemplateColumn Header="DI+&#x0A;DI-" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridDiPlus}"  FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource BuyBrush}"/>
                                                        <TextBlock Text="{Binding GridDiMinus}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource SellBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- MACD / MACD Prev (stacked) -->
                                        <DataGridTemplateColumn Header="MACD&#x0A;MACD Prev" Width="82">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,4" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding GridMacd}"     FontFamily="Consolas" FontSize="12"/>
                                                        <TextBlock Text="{Binding GridMacdPrev}" FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Stoch RSI -->
                                        <DataGridTextColumn Header="Stoch&#x0A;RSI"  Binding="{Binding GridStochRsi}"   Width="50"/>
                                        <!-- Long x/7 -->
                                        <DataGridTextColumn Header="Long&#x0A;x/7"   Binding="{Binding GridLongScore}"  Width="46"/>
                                        <!-- Short x/7 -->
                                        <DataGridTextColumn Header="Short&#x0A;x/7"  Binding="{Binding GridShortScore}" Width="46"/>
                                        <!-- Conf -->
                                        <DataGridTextColumn Header="Conf"             Binding="{Binding GridConf}"       Width="90"/>
                                        <!-- Explain: 3-line natural-language summary of which conditions pass/fail -->
                                        <DataGridTemplateColumn Header="Explain" Width="*" MinWidth="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding GridExplain}"
                                                               FontFamily="Consolas" FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="6,4"
                                                               VerticalAlignment="Top"
                                                               ToolTip="{Binding GridExplain}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- ══ No-strategy placeholder ════════════════════════════════════════ -->
                                <TextBlock Text="Select a strategy above to view the live indicator grid."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,20">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEmaRsiActive}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMultiConfluenceActive}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>
                        </Border>

                    </Grid>
                </UserControl>
