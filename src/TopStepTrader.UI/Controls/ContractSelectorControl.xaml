<UserControl x:Class="TopStepTrader.UI.Controls.ContractSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="300"
             MinHeight="28">

    <ComboBox x:Name="ContractComboBox"
              HorizontalAlignment="Stretch"
              MinWidth="200"
              SelectionChanged="OnSelectionChanged"
              Style="{StaticResource UnclippedComboBoxStyle}"
              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
        <!--  ItemTemplate creates a NEW TextBlock per render slot (header + each
              dropdown row). Foreground="White" is a local DP value — the highest
              possible priority in WPF's property system. Nothing in the system
              theme can override it.  -->
        <ComboBox.ItemTemplate>
            <DataTemplate>
                <TextBlock Text="{Binding Display}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </DataTemplate>
        </ComboBox.ItemTemplate>
    </ComboBox>

</UserControl>
