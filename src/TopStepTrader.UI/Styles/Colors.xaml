<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Background palette ═══ -->
    <Color x:Key="BackgroundColor">#FF1A1A2E</Color>
    <Color x:Key="SidebarColor">#FF16213E</Color>
    <Color x:Key="SurfaceColor">#FF1E2A4A</Color>
    <Color x:Key="CardColor">#FF243156</Color>
    <Color x:Key="BorderColor">#FF2E3F6E</Color>

    <!-- ═══ Accent / action colours ═══ -->
    <Color x:Key="AccentColor">#FF27AE60</Color>
    <Color x:Key="BuyColor">#FF00C851</Color>
    <Color x:Key="SellColor">#FFFF4444</Color>
    <Color x:Key="WarningColor">#FFFFBB00</Color>
    <Color x:Key="HaltedColor">#FFFF6B35</Color>

    <!-- ═══ Text ═══ -->
    <Color x:Key="TextPrimaryColor">#FFE0E0F0</Color>
    <Color x:Key="TextSecondaryColor">#FF8080A0</Color>
    <Color x:Key="TextDisabledColor">#FF505070</Color>
    <Color x:Key="TextHeaderColor">#FF4A9FFF</Color>

    <!-- ═══ Brushes ═══ -->
    <SolidColorBrush x:Key="BackgroundBrush"     Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBrush"        Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush"           Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="BorderBrush"         Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="BuyBrush"            Color="{StaticResource BuyColor}"/>
    <SolidColorBrush x:Key="SellBrush"           Color="{StaticResource SellColor}"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="HaltedBrush"         Color="{StaticResource HaltedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush"   Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="TextHeaderBrush"     Color="{StaticResource TextHeaderColor}"/>

    <!-- Nav button hover/selected overlays -->
    <Color x:Key="NavHoverColor">#22FFFFFF</Color>
    <Color x:Key="NavSelectedColor">#3327AE60</Color>
    <SolidColorBrush x:Key="NavHoverBrush"    Color="{StaticResource NavHoverColor}"/>
    <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelectedColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
